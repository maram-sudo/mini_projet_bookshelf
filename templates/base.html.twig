{# templates/base.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{% block title %}BookShelf{% endblock %} — Bibliothèque en Ligne</title>

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>

 <link rel="stylesheet" href="{{ asset('css/bookshelf.css') }}"/>
</head>
<body>

  {# ── NAVBAR ── #}
  <nav>
    <div class="nav-logo">
      <span class="logo-icon">📚</span>
      <a href="{{ path('livre_index') }}">Book<span>Shelf</span></a>
    </div>
    <ul class="nav-links">
      <li><a href="{{ path('livre_index') }}">Catalogue</a></li>
      <li><a href="{{ path('livre_new') }}">Ajouter un livre</a></li>
    </ul>
    <div class="nav-actions">
      {% if app.user %}
        <span style="color:var(--dust)">👤 {{ app.user.email }}</span>
        <a href="{{ path('app_logout') }}" class="btn-ghost">Déconnexion</a>
      {% else %}
        <a href="{{ path('app_login') }}" class="btn-ghost">Connexion</a>
        <a href="{{ path('app_register') }}" class="btn-primary">S'inscrire</a>
      {% endif %}
    </div>
  </nav>

  {# ── FLASH MESSAGES ── #}
  {% for message in app.flashes('success') %}
    <div style="background:var(--sage);color:#fff;padding:.8rem 2rem;">✓ {{ message }}</div>
  {% endfor %}
  {% for message in app.flashes('error') %}
    <div style="background:var(--rust);color:#fff;padding:.8rem 2rem;">✗ {{ message }}</div>
  {% endfor %}

  {# ── CONTENU PRINCIPAL ── #}
  {% block body %}{% endblock %}

  {# ── FOOTER ── #}
  <footer>
    <div class="footer-bottom">
      <p>© {{ "now"|date("Y") }} BookShelf · Tous droits réservés</p>
    </div>
  </footer>


  {% block javascripts %}{% endblock %}

</body>
</html>